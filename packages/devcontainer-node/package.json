{
  "name": "@lvce-editor/devcontainer-node",
  "version": "0.0.0-dev",
  "keywords": [
    "lvce-editor",
    "devcontainer"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/lvce-editor/devcontainer.git"
  },
  "license": "MIT",
  "author": "Lvce Editor",
  "type": "module",
  "main": "src/devcontainerNodeMain.ts",
  "bin": {
    "devcontainer-node": "bin/devcontainerNode.js"
  },
  "scripts": {
    "test": "node --unhandled-rejections=warn --experimental-vm-modules ./node_modules/jest/bin/jest.js --detectOpenHandles --forceExit",
    "test:watch": "node --unhandled-rejections=warn --experimental-vm-modules ./node_modules/jest/bin/jest.js --watch"
  },
  "jest": {
    "injectGlobals": false,
    "extensionsToTreatAsEsm": [
      ".ts"
    ],
    "moduleNameMapper": {
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transform": {
      "^.+\\.tsx?$": [
        "ts-jest",
        {
          "useESM": true
        }
      ]
    }
  },
  "dependencies": {
    "@devcontainers/cli": "^0.87.0",
    "@lvce-editor/assert": "^1.5.1",
    "@lvce-editor/pretty-error": "^2.0.0",
    "@lvce-editor/rpc": "^6.4.0"
  },
  "devDependencies": {
    "@jest/globals": "^30.4.1",
    "@types/jest": "^30.0.0",
    "jest": "^30.4.2",
    "ts-jest": "^29.4.11"
  }
}
